/* /////////////////Time Line//////// */
    

    .myultim {
        --col-gap: 2rem;
        --row-gap: 2rem;
        --line-w: 0.25rem;
        display: grid;
        grid-template-columns: var(--line-w) 1fr;
        grid-auto-columns: max-content;
        column-gap: var(--col-gap);
/*         list-style: none; */
        width: min(60rem, 90%);
        margin-inline: auto;
    }

    /* line */
    .myultim::before {
        content: "";
        grid-column: 1;
        grid-row: 1 / span 20;
        background: #727272;
        border-radius: calc(var(--line-w) / 2);
    }

    /* columns*/

    /* row gaps */
    .myultim .timli:not(:last-child) {
        margin-bottom: var(--row-gap);
    }

    /* card */
    .myultim .timli {
        grid-column: 2;
        --inlineP: 1.5rem;
        margin-inline: var(--inlineP);
        grid-row: span 2;
        display: grid;
        grid-template-rows: min-content min-content min-content;
    }

    /* datetim */
    .myultim .timli .datetim {
        --datetimH: 3rem;
        height: var(--datetimH);
        margin-inline: calc(var(--inlineP) * -1);

        text-align: center;
        background-color: var(--accent-color);

        color: white;
        font-size: 1.25rem;
        font-weight: 700;

        display: grid;
        place-content: center;
        position: relative;

        border-radius: calc(var(--datetimH) / 2) 0 0 calc(var(--datetimH) / 2);
    }

    /* datetim flap */
    .myultim .timli .datetim::before {
        content: "";
        width: var(--inlineP);
        aspect-ratio: 1;
        background: var(--accent-color);
        background-image: linear-gradient(rgba(0, 0, 0, 0.2) 100%, transparent);
        position: absolute;
        top: 100%;

        clip-path: polygon(0 0, 100% 0, 0 100%);
        right: 0;
    }
    .titlemmy{
        font-family: poppins;
        font-weight: 700;
        font-size: 20px;
        line-height: 1.3rem;
    }

    /* circle */
    .myultim .timli .datetim::after {
        content: "";
        position: absolute;
        width: 2rem;
        aspect-ratio: 1;
        background: var(--bgColor);
        border: 0.3rem solid var(--accent-color);
        border-radius: 50%;
        top: 50%;

        transform: translate(50%, -50%);
        right: calc(100% + var(--col-gap) + var(--line-w) / 2);
    }

    /* titlemmy descr */
    .myultim .timli .titlemmy,
    .myultim .timli .descr {
        background: var(--bgColor);
        position: relative;
    }
    .descr{
        font-size: 16px;
        font-family: montserrat;
    }
    .myultim .timli .titlemmy {
        overflow: hidden;
        padding-block-start: 1.5rem;
        padding-block-end: 1rem;
    }
.titlemmy{
	font-family:Raleway;
	font-size:30px;
	font-weight:700;
	line-height:36px;
	color:black;
}
    .myultim .descr {
        padding-block-end: 1.5rem;
        font-weight: 300;
    }
    .datetim{
        font-size: 20px;
        font-family: Raleway;
    }

    /* shadows */
    .myultim .timli .titlemmy::before,
    .myultim .timli .descr::before {
        content: "";
        position: absolute;
        width: 90%;
        height: 0.5rem;
        background: rgba(0, 0, 0, 0.5);
        left: 50%;
        border-radius: 50%;
        filter: blur(4px);
        transform: translate(-50%, 50%);
    }

    .myultim .timli .titlemmy::before {
        bottom: calc(100% + 0.125rem);
    }

    .myultim .timli .descr::before {
        z-index: -1;
        bottom: 0.25rem;
    }

    @media (min-width: 40rem) {
        .myultim {
            grid-template-columns: 1fr var(--line-w) 1fr;
        }

        .myultim::before {
            grid-column: 2;
        }

        .myultim .timli:nth-child(odd) {
            grid-column: 1;
						margin-bottom:80px !important;
        }

        .myultim .timli:nth-child(even) {
            grid-column: 3;
					
        }

        /* start second card */
        .myultim .timli:nth-child(2) {
            grid-row: 2/4;
        }

        .myultim .timli:nth-child(odd) .datetim::before {
            clip-path: polygon(0 0, 100% 0, 100% 100%);
            left: 0;
				
        }

        .myultim .timli:nth-child(odd) .datetim::after {
            transform: translate(-50%, -50%);
            left: calc(100% + var(--col-gap) + var(--line-w) / 2);
        }

        .myultim .timli:nth-child(odd) .datetim {
            border-radius: 0 calc(var(--datetimH) / 2) calc(var(--datetimH) / 2) 0;
        }
    }

.myultim :hover .datetim{
	background:black !important;
}
.myultim :hover .datetim::before{
		background:linear-gradient(rgb(0 0 0 / 49%) 100%, #ffffff00) !important;

}

		</style>
		<!-- end wp_head -->
</head>


